# Local example environment variables (do NOT commit secrets)
# Copy this to .env for local development and fill in real values.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=famili
SPRING_DATASOURCE_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRATION_SECONDS=3600

# App
APP_NAME=famili-backend
ADMIN_EMAIL=admin@example.com

# Flyway
FLYWAY_ENABLED=true
